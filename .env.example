# --- 核心資料源 (台股籌碼與財報) ---
# 前往 https://finmindtrade.com/ 取得 Token (非必填，不填則使用 FinMind 免費 API 限制)
FINMIND_API_TOKEN=your_finmind_token_here

# --- AI 戰術大腦 (必填其一) ---
# Groq: 極速推理，前往 https://console.groq.com/ 取得 (推薦)
GROQ_API_KEY=gsk_...
# Gemini: 穩定備援，前往 https://aistudio.google.com/ 取得
GEMINI_API_KEY=AIzaSy...

# --- 全局快取與線上人數統計 (必填) ---
# 前往 https://upstash.com/ 建立 Serverless Redis
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# --- Telegram 智能推播 (選填) ---
# 向 @BotFather 申請機器人取得 Token
TELEGRAM_BOT_TOKEN=your_bot_token
# 向 @userinfobot 取得您的 Chat ID
TELEGRAM_CHAT_ID=your_chat_id

# --- 系統設定 (選填) ---
# Cron Job 定時掃描的自選股清單 (以逗號分隔)
WATCHLIST_TW=2330,2317,2454
# 專案 Base URL (用於 Telegram 圖片路徑)
APP_BASE_URL=https://your-project.vercel.app
